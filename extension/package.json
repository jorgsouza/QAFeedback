{
  "name": "qa-feedback-github",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build:bridge": "esbuild src/injected/page-bridge.ts --bundle --format=iife --platform=browser --target=es2020 --outfile=dist/page-bridge.js",
    "icons": "node scripts/roundify-capiqa.mjs",
    "dev": "npm run icons && vite build && BUILD_TARGET=content vite build && npm run build:bridge && node scripts/copy-manifest.mjs",
    "build": "npm run icons && vite build && BUILD_TARGET=content vite build && npm run build:bridge && node scripts/copy-manifest.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.24.2",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.0"
  }
}
