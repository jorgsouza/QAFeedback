{
  "manifest_version": 3,
  "name": "QA Feedback → GitHub",
  "version": "0.1.0",
  "description": "Abra issues no GitHub a partir da página em teste, com formulário e preview.",
  "permissions": ["storage", "scripting", "activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "QA Feedback — mostrar botão nesta página"
  },
  "host_permissions": [
    "https://api.github.com/*",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js", "qa.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
