{
  "manifest_version": 3,
  "name": "QA Feedback — GitHub e Jira",
  "version": "0.2.0",
  "description": "Envie feedback como issue no GitHub e/ou no Jira (Atlassian Cloud), a partir da página em teste.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "debugger",
    "tabs",
    "tabCapture",
    "offscreen"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "QA Feedback — mostrar botão nesta página"
  },
  "host_permissions": [
    "https://api.github.com/*",
    "https://*.atlassian.net/*",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "https://www.reclameaqui.com.br/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js",
        "qa.png",
        "check_positivo.svg",
        "jiraBoard.svg",
        "jiraIssue.svg"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
