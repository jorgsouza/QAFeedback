# Copie para `.env` na raiz do repositório (nunca commite `.env`).

# --- Google Gemini (serviço ia-feedback) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Chave que a extensão envia no header Authorization ao chamar o teu backend
# (não confundir com GEMINI_API_KEY).
IA_FEEDBACK_API_KEY=

# Porta local do serviço HTTP (opcional)
PORT=8787

# --- Jira (futuro / outras integrações) ---
# JIRA_USER=
# JIRA_TOKEN=
# JIRA_BASE_URL=
